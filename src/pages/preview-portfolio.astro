---
import Layout from "../layouts/Layout.astro";
const projects = [
  { name: "Hartley & Co", type: "Plumbing", url: "https://hartley.maddrelldesign.com", img: "/thumbnails/hartley.webp" },
  { name: "Kin Grain", type: "Cafe", url: "https://cafe.maddrelldesign.com", img: "/thumbnails/cafe.webp" },
  { name: "Apex Fitness", type: "Gym", url: "https://fitness.maddrelldesign.com", img: "/thumbnails/fitness.webp" },
];
---

<Layout title="Portfolio Section Options">

<div class="px-4 py-8 max-w-[1100px] mx-auto">
  <h1 class="font-cal text-[28px] font-bold text-[#242424] mb-2">Recent Launches Options</h1>
  <p class="text-[14px] text-[#6b6b6b] mb-10">Three different display styles for the portfolio/work section.</p>
</div>

<!-- ═══════════════ OPTION 1: Interactive Carousel ═══════════════ -->
<section class="grid-bg py-10 sm:py-14 px-4 sm:px-6">
  <div class="max-w-[640px] md:max-w-[1000px] mx-auto">
    <span class="inline-block px-3 py-1 rounded-full bg-[#3b82f6] text-white text-[12px] font-bold mb-6">Option 1: Swipeable Carousel</span>
    <div class="mb-8">
      <div class="cal-pill">
        <svg class="w-4 h-4 text-[#3b82f6]" viewBox="0 0 20 20" fill="currentColor"><path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 6a1 1 0 011-1h12a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6z"/></svg>
        Recent launches
      </div>
      <h2 class="font-cal text-[28px] sm:text-[32px] font-bold leading-[1.08] text-[#242424] mb-3" style="letter-spacing:-0.035em;text-wrap:balance">
        Crafted this week, built to last
      </h2>
    </div>

    <!-- Carousel -->
    <div class="relative overflow-hidden">
      <div id="carousel-track" class="flex gap-4 transition-transform duration-500 ease-out">
        {projects.map((p, i) => (
          <a href={p.url} target="_blank" rel="noopener" class="group flex-shrink-0 w-[85%] sm:w-[70%] md:w-[60%]">
            <div class="cal-card overflow-hidden">
              <div class="aspect-[16/9] overflow-hidden bg-[#f4f4f4]">
                <img src={p.img} alt={p.name} loading="lazy" class="w-full h-full object-cover object-top group-hover:scale-[1.03] transition-transform duration-700" />
              </div>
              <div class="flex items-center justify-between px-5 py-4">
                <div>
                  <span class="text-[16px] font-semibold text-[#242424]">{p.name}</span>
                  <span class="text-[13px] text-[#9a9a9a] ml-2">{p.type}</span>
                </div>
                <svg class="w-4 h-4 text-[#d0d0d0] group-hover:text-[#242424] transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
      <!-- Nav arrows -->
      <div class="flex items-center gap-2 mt-4">
        <button onclick="document.getElementById('carousel-track').scrollBy({left:-300,behavior:'smooth'})" class="w-9 h-9 rounded-xl bg-white border border-[#e8e8e8] flex items-center justify-center hover:bg-[#f4f4f4] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
        </button>
        <button onclick="document.getElementById('carousel-track').scrollBy({left:300,behavior:'smooth'})" class="w-9 h-9 rounded-xl bg-white border border-[#e8e8e8] flex items-center justify-center hover:bg-[#f4f4f4] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ OPTION 2: Stacked Cards ═══════════════ -->
<section class="grid-bg py-10 sm:py-14 px-4 sm:px-6">
  <div class="max-w-[640px] md:max-w-[1000px] mx-auto">
    <span class="inline-block px-3 py-1 rounded-full bg-[#f97316] text-white text-[12px] font-bold mb-6">Option 2: Stacked/Layered Cards</span>
    <div class="mb-8">
      <div class="cal-pill">
        <svg class="w-4 h-4 text-[#3b82f6]" viewBox="0 0 20 20" fill="currentColor"><path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 6a1 1 0 011-1h12a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6z"/></svg>
        Recent launches
      </div>
      <h2 class="font-cal text-[28px] sm:text-[32px] font-bold leading-[1.08] text-[#242424] mb-3" style="letter-spacing:-0.035em;text-wrap:balance">
        Crafted this week, built to last
      </h2>
    </div>

    <!-- Stacked cards -->
    <div class="relative" style="height:420px">
      {projects.map((p, i) => (
        <a href={p.url} target="_blank" rel="noopener"
          class="stacked-card group absolute inset-x-0 cal-card overflow-hidden transition-all duration-500"
          style={`top:${i * 16}px; z-index:${30 - i}; transform:scale(${1 - i * 0.03}); opacity:${1 - i * 0.15}`}
          data-index={i}>
          <div class="aspect-[16/9] overflow-hidden bg-[#f4f4f4]">
            <img src={p.img} alt={p.name} loading="lazy" class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-700" />
          </div>
          <div class="flex items-center justify-between px-5 py-4 bg-white">
            <div>
              <span class="text-[16px] font-semibold text-[#242424]">{p.name}</span>
              <span class="text-[13px] text-[#9a9a9a] ml-2">{p.type}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[11px] text-[#9a9a9a]">{i + 1} of {projects.length}</span>
              <svg class="w-4 h-4 text-[#d0d0d0] group-hover:text-[#242424] transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════ OPTION 3: Bento Grid ═══════════════ -->
<section class="grid-bg py-10 sm:py-14 px-4 sm:px-6">
  <div class="max-w-[640px] md:max-w-[1000px] mx-auto">
    <span class="inline-block px-3 py-1 rounded-full bg-[#8b5cf6] text-white text-[12px] font-bold mb-6">Option 3: Bento Grid</span>
    <div class="mb-8">
      <div class="cal-pill">
        <svg class="w-4 h-4 text-[#3b82f6]" viewBox="0 0 20 20" fill="currentColor"><path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 6a1 1 0 011-1h12a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6z"/></svg>
        Recent launches
      </div>
      <h2 class="font-cal text-[28px] sm:text-[32px] font-bold leading-[1.08] text-[#242424] mb-3" style="letter-spacing:-0.035em;text-wrap:balance">
        Crafted this week, built to last
      </h2>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <!-- Featured large card -->
      <a href={projects[0].url} target="_blank" rel="noopener" class="sm:col-span-2 group cal-card overflow-hidden">
        <div class="aspect-[2/1] sm:aspect-[21/9] overflow-hidden bg-[#f4f4f4]">
          <img src={projects[0].img} alt={projects[0].name} loading="lazy" class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-700" />
        </div>
        <div class="flex items-center justify-between px-5 py-4">
          <div>
            <span class="text-[16px] font-semibold text-[#242424]">{projects[0].name}</span>
            <span class="text-[13px] text-[#9a9a9a] ml-2">{projects[0].type}</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="px-2 py-0.5 rounded-md bg-[#f0fdf4] text-[10px] font-medium text-[#22c55e]">Featured</span>
            <svg class="w-4 h-4 text-[#d0d0d0] group-hover:text-[#242424] transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
          </div>
        </div>
      </a>
      <!-- Two smaller cards -->
      {projects.slice(1).map(p => (
        <a href={p.url} target="_blank" rel="noopener" class="group cal-card overflow-hidden">
          <div class="aspect-[16/9] overflow-hidden bg-[#f4f4f4]">
            <img src={p.img} alt={p.name} loading="lazy" class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-700" />
          </div>
          <div class="flex items-center justify-between px-4 py-3">
            <div>
              <span class="text-[14px] font-semibold text-[#242424]">{p.name}</span>
              <span class="text-[12px] text-[#9a9a9a] ml-2">{p.type}</span>
            </div>
            <svg class="w-4 h-4 text-[#d0d0d0] group-hover:text-[#242424] transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  #carousel-track {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  #carousel-track::-webkit-scrollbar { display: none; }
  #carousel-track > * { scroll-snap-align: start; }
</style>

</Layout>
