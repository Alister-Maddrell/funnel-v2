---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Maddrell Design | Premium Websites for Local Business">

<!-- ═══════════════ NAV ═══════════════ -->
<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-200">
  <div class="flex items-center justify-between px-4 py-3 max-w-[1200px] mx-auto">
    <!-- Logo with custom mark -->
    <a href="/" class="flex items-center gap-2">
      <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[#292929] to-[#242424] flex items-center justify-center shadow-sm">
        <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
      </div>
      <span class="font-cal text-[16px] font-bold text-[#242424] tracking-[-0.02em]">Maddrell</span>
    </a>
    <div class="flex items-center gap-2">
      <a href="https://portfolio.maddrelldesign.com" target="_blank" class="hidden sm:block text-[13px] text-[#6b6b6b] hover:text-[#242424] transition-colors px-2 py-1">Portfolio</a>
      <a href="/book" class="cal-btn-dark chevron text-[13px] py-[8px] px-[14px]">Get started</a>
      <button id="menu-btn" class="sm:hidden w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white/50 transition-colors" aria-label="Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
      </button>
    </div>
  </div>
</nav>

<!-- ═══════════════ MOBILE MENU ═══════════════ -->
<div id="mobile-menu" class="fixed inset-0 z-[60] hidden">
  <div class="absolute inset-0 bg-black/20 backdrop-blur-sm" id="menu-backdrop"></div>
  <div class="absolute top-0 right-0 w-[280px] h-full bg-white shadow-2xl p-6 pt-16 overflow-y-auto">
    <button id="menu-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-lg hover:bg-[#f4f4f4]">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <div class="flex flex-col gap-0.5">
      <a href="https://portfolio.maddrelldesign.com" target="_blank" class="px-3 py-2.5 rounded-lg text-[14px] text-[#6b6b6b] hover:bg-[#f4f4f4]">Portfolio</a>
      <a href="#how-it-works" class="px-3 py-2.5 rounded-lg text-[14px] text-[#6b6b6b] hover:bg-[#f4f4f4]">How it works</a>
      <a href="#benefits" class="px-3 py-2.5 rounded-lg text-[14px] text-[#6b6b6b] hover:bg-[#f4f4f4]">Benefits</a>
      <a href="#pricing" class="px-3 py-2.5 rounded-lg text-[14px] text-[#6b6b6b] hover:bg-[#f4f4f4]">Pricing</a>
      <a href="/book" class="px-3 py-2.5 rounded-lg text-[14px] text-[#6b6b6b] hover:bg-[#f4f4f4]">Book a call</a>
      <div class="border-t border-[#e8e8e8] my-2 pt-2">
        <p class="px-3 py-1 text-[11px] font-semibold text-[#9a9a9a] uppercase tracking-wider">Demo Sites</p>
        <a href="https://hartley.maddrelldesign.com" target="_blank" class="px-3 py-2 rounded-lg text-[13px] text-[#9a9a9a] hover:bg-[#f4f4f4] block">Hartley Plumbing</a>
        <a href="https://cafe.maddrelldesign.com" target="_blank" class="px-3 py-2 rounded-lg text-[13px] text-[#9a9a9a] hover:bg-[#f4f4f4] block">Kin Grain Cafe</a>
        <a href="https://fitness.maddrelldesign.com" target="_blank" class="px-3 py-2 rounded-lg text-[13px] text-[#9a9a9a] hover:bg-[#f4f4f4] block">Apex Fitness</a>
        <a href="https://beauty.maddrelldesign.com" target="_blank" class="px-3 py-2 rounded-lg text-[13px] text-[#9a9a9a] hover:bg-[#f4f4f4] block">Luma Beauty</a>
        <a href="https://accounting.maddrelldesign.com" target="_blank" class="px-3 py-2 rounded-lg text-[13px] text-[#9a9a9a] hover:bg-[#f4f4f4] block">Whitfield Accounting</a>
        <a href="https://events.maddrelldesign.com" target="_blank" class="px-3 py-2 rounded-lg text-[13px] text-[#9a9a9a] hover:bg-[#f4f4f4] block">Evergreen Events</a>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════ HERO ═══════════════ -->
<section id="hero" class="pt-14 grid-bg">
  <div class="cal-card mx-3 sm:mx-4 md:mx-auto md:max-w-[1100px]">
    <div class="px-5 pt-10 pb-6 sm:px-8 sm:pt-14 md:px-10 md:pt-16">
      <!-- Badge -->
      <a href="#benefits" class="cal-pill mb-6">
        <svg class="w-4 h-4 text-[#6349ea]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        Sydney's premium web studio
        <svg class="w-3.5 h-3.5 text-[#9a9a9a]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
      </a>

      <!-- H1 — Cal Sans, 40px, weight 600 -->
      <h1 class="font-cal text-[36px] sm:text-[40px] md:text-[52px] font-semibold leading-[1.1] text-[#242424] mb-5">
        The better way to launch your business online
      </h1>

      <!-- Subtext -->
      <p class="text-[14px] sm:text-[15px] leading-[1.65] text-[#6b6b6b] max-w-[380px] mb-7">
        Bespoke websites for ambitious local businesses. Hand-coded for performance, designed for conversions, delivered in 10 days.
      </p>

      <!-- CTA pair -->
      <div class="max-w-[320px] flex flex-col gap-2.5 mb-5">
        <a href="/book" class="cal-btn-full">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Book a free strategy call
        </a>
        <a href="#pricing" class="cal-btn-full-outline">
          View packages &amp; pricing
          <svg class="w-4 h-4 text-[#9a9a9a]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
        </a>
      </div>

      <p class="text-[12px] text-[#9a9a9a]">Free consultation · Zero obligation</p>
    </div>

    <!-- Calendly Embed -->
    <div class="px-4 pb-6 sm:px-6 md:px-8">
      <div class="rounded-xl border border-[#e8e8e8] bg-[#f8f8f8] overflow-hidden" style="min-height: 400px;">
        <div class="calendly-inline-widget" data-url="https://calendly.com/alistermaddrell/15min" style="min-width:280px;height:480px;"></div>
      </div>
    </div>

    <!-- Trust badges -->
    <div class="flex items-center justify-center gap-6 sm:gap-8 px-5 pb-6 border-t border-[#f0f0f0] pt-5">
      <div class="flex flex-col items-center gap-1">
        <div class="flex gap-0.5">
          {[1,2,3,4,5].map(() => <svg class="w-3.5 h-3.5 text-[#f59e0b]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
        </div>
        <span class="text-[10px] text-[#9a9a9a] font-medium">100% Hand-coded</span>
      </div>
      <div class="w-px h-6 bg-[#e8e8e8]"></div>
      <div class="flex flex-col items-center gap-1">
        <span class="text-[14px] font-bold text-[#242424]">10 days</span>
        <span class="text-[10px] text-[#9a9a9a] font-medium">Average delivery</span>
      </div>
      <div class="w-px h-6 bg-[#e8e8e8]"></div>
      <div class="flex flex-col items-center gap-1">
        <span class="text-[14px] font-bold text-[#242424]">&lt; 2s</span>
        <span class="text-[10px] text-[#9a9a9a] font-medium">Page load speed</span>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ TRUSTED BY ═══════════════ -->
<div class="py-10 px-5 grid-bg">
  <p class="text-center text-[12px] text-[#9a9a9a] mb-5">Trusted by growing businesses across Sydney</p>
  <div class="flex items-center justify-center gap-8 sm:gap-12 opacity-25 grayscale">
    <span class="text-[17px] font-bold text-[#242424]">Hartley</span>
    <span class="text-[17px] font-bold text-[#242424]" style="font-family:serif">Kin Grain</span>
    <span class="text-[17px] font-bold text-[#242424] tracking-wider uppercase text-[14px]">APEX</span>
    <span class="text-[17px] font-bold text-[#242424] hidden sm:block" style="font-family:serif;font-style:italic">Luma</span>
  </div>
</div>

<!-- ═══════════════ HOW IT WORKS — TIMELINE ═══════════════ -->
<section id="how-it-works" class="px-4 sm:px-6 py-10 sm:py-14 grid-bg">
  <div class="max-w-[640px] md:max-w-[1000px] mx-auto">
    <div class="mb-8 fade-in">
      <div class="cal-pill">
        <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none"><circle cx="4" cy="4" r="3" fill="#3b82f6"/><circle cx="10" cy="8" r="3" fill="#f97316"/><circle cx="16" cy="12" r="3" fill="#8b5cf6"/><circle cx="10" cy="16" r="3" fill="#22c55e"/><path d="M6 5.5l3 1.5M12 9.5l3 1.5M13 13.5l-2 1.5" stroke="#e8e8e8" stroke-width="1"/></svg>
        How it works
      </div>
      <h2 class="font-cal text-[28px] sm:text-[32px] font-semibold leading-[1.1] text-[#242424] mb-3">
        From brief to live in four simple steps
      </h2>
      <p class="text-[14px] sm:text-[15px] leading-[1.6] text-[#6b6b6b] max-w-[420px]">
        Your total time commitment: about 30 minutes. We handle the design, development, and deployment — you focus on running your business.
      </p>
      <div class="flex items-center gap-3 mt-5">
        <a href="/book" class="cal-btn-dark chevron">Get started</a>
        <a href="/book" class="cal-btn-outline chevron">Book a demo</a>
      </div>
    </div>

    <!-- Timeline steps -->
    <div id="timeline-container" class="relative max-w-[500px]">
      <!-- Track -->
      <div class="absolute left-[23px] top-0 bottom-0 w-[2px] bg-[#e8e8e8] rounded-full"></div>
      <div id="timeline-progress" class="absolute left-[23px] top-0 w-[2px] rounded-full" style="height:0;background:linear-gradient(to bottom,#3b82f6,#f97316,#8b5cf6,#22c55e);transition:height 0.5s cubic-bezier(0.16,1,0.3,1);"></div>

      <!-- Step 01 -->
      <div class="timeline-step relative flex gap-5 pb-6" data-color="#3b82f6">
        <div class="relative z-10 w-[48px] shrink-0 flex flex-col items-center">
          <div class="timeline-node w-11 h-11 rounded-xl bg-white border-2 border-[#e8e8e8] flex items-center justify-center transition-all duration-500">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" fill="#eff6ff" stroke="#3b82f6" stroke-width="1.5"/><path d="M8 12h8M12 8v8" stroke="#3b82f6" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
        </div>
        <div class="cal-card p-5 flex-1 timeline-content opacity-50 translate-y-2 transition-all duration-500">
          <span class="text-[10px] font-bold tracking-wider text-[#9a9a9a] uppercase">Step 01</span>
          <h3 class="text-[17px] font-semibold text-[#242424] mt-1 mb-1.5" style="letter-spacing:-0.2px">Share your vision</h3>
          <p class="text-[14px] leading-[1.6] text-[#6b6b6b]">A quick brief about your business, audience, and goals. We'll handle content strategy, photography sourcing, and site architecture.</p>
          <!-- Illustration: form/clipboard -->
          <div class="mt-4 p-4 rounded-xl bg-[#eff6ff] border border-[#dbeafe]">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 rounded-lg bg-[#3b82f6] flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>
              </div>
              <div class="flex-1">
                <div class="h-2 rounded bg-[#93c5fd] w-3/4 mb-1.5"></div>
                <div class="h-2 rounded bg-[#bfdbfe] w-1/2"></div>
              </div>
            </div>
            <div class="space-y-2">
              <div class="flex items-center gap-2">
                <div class="w-4 h-4 rounded border-2 border-[#3b82f6] flex items-center justify-center"><svg class="w-3 h-3 text-[#3b82f6]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg></div>
                <div class="h-2 rounded bg-[#93c5fd] flex-1"></div>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-4 h-4 rounded border-2 border-[#3b82f6] flex items-center justify-center"><svg class="w-3 h-3 text-[#3b82f6]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg></div>
                <div class="h-2 rounded bg-[#bfdbfe] flex-1"></div>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-4 h-4 rounded border-2 border-[#dbeafe]"></div>
                <div class="h-2 rounded bg-[#dbeafe] w-2/3"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 02 -->
      <div class="timeline-step relative flex gap-5 pb-6" data-color="#f97316">
        <div class="relative z-10 w-[48px] shrink-0 flex flex-col items-center">
          <div class="timeline-node w-11 h-11 rounded-xl bg-white border-2 border-[#e8e8e8] flex items-center justify-center transition-all duration-500">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" fill="#fff7ed" stroke="#f97316" stroke-width="1.5"/><path d="M7 8h10M7 12h6" stroke="#f97316" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
        </div>
        <div class="cal-card p-5 flex-1 timeline-content opacity-50 translate-y-2 transition-all duration-500">
          <span class="text-[10px] font-bold tracking-wider text-[#9a9a9a] uppercase">Step 02</span>
          <h3 class="text-[17px] font-semibold text-[#242424] mt-1 mb-1.5" style="letter-spacing:-0.2px">Approve the blueprint</h3>
          <p class="text-[14px] leading-[1.6] text-[#6b6b6b]">Review a detailed wireframe before we write a single line of code. Every element placed with intention — nothing moves without your sign-off.</p>
          <!-- Illustration: wireframe layout -->
          <div class="mt-4 p-4 rounded-xl bg-[#fff7ed] border border-[#fed7aa]">
            <div class="flex gap-2 mb-2">
              <div class="h-3 rounded bg-[#fdba74] flex-1"></div>
              <div class="h-3 rounded bg-[#fed7aa] w-12"></div>
            </div>
            <div class="h-16 rounded bg-[#fed7aa] mb-2"></div>
            <div class="grid grid-cols-3 gap-2">
              <div class="h-10 rounded bg-[#fdba74]/50"></div>
              <div class="h-10 rounded bg-[#fdba74]/50"></div>
              <div class="h-10 rounded bg-[#fdba74]/50"></div>
            </div>
            <div class="mt-2 flex items-center justify-center">
              <div class="px-3 py-1 rounded-md bg-[#f97316] text-white text-[10px] font-medium">Approved ✓</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 03 -->
      <div class="timeline-step relative flex gap-5 pb-6" data-color="#8b5cf6">
        <div class="relative z-10 w-[48px] shrink-0 flex flex-col items-center">
          <div class="timeline-node w-11 h-11 rounded-xl bg-white border-2 border-[#e8e8e8] flex items-center justify-center transition-all duration-500">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" rx="2" fill="#f5f3ff" stroke="#8b5cf6" stroke-width="1.5"/><path d="M8 12l3 3 5-6" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>
        <div class="cal-card p-5 flex-1 timeline-content opacity-50 translate-y-2 transition-all duration-500">
          <span class="text-[10px] font-bold tracking-wider text-[#9a9a9a] uppercase">Step 03</span>
          <h3 class="text-[17px] font-semibold text-[#242424] mt-1 mb-1.5" style="letter-spacing:-0.2px">Preview &amp; refine</h3>
          <p class="text-[14px] leading-[1.6] text-[#6b6b6b]">Get a live preview link to test on your phone. Share it with your team. Two revision rounds to polish every detail until it's perfect.</p>
          <!-- Illustration: browser preview -->
          <div class="mt-4 rounded-xl border border-[#ddd6fe] overflow-hidden">
            <div class="flex items-center gap-1.5 px-3 py-2 bg-[#f5f3ff] border-b border-[#ddd6fe]">
              <span class="w-2 h-2 rounded-full bg-[#c4b5fd]"></span>
              <span class="w-2 h-2 rounded-full bg-[#c4b5fd]"></span>
              <span class="w-2 h-2 rounded-full bg-[#c4b5fd]"></span>
              <div class="flex-1 mx-2 h-4 rounded bg-[#ede9fe] flex items-center justify-center">
                <span class="text-[9px] text-[#8b5cf6]">preview.maddrelldesign.com</span>
              </div>
            </div>
            <div class="p-3 bg-[#faf5ff]">
              <div class="h-2 rounded bg-[#ddd6fe] w-3/4 mb-2"></div>
              <div class="h-8 rounded bg-[#ede9fe] mb-2"></div>
              <div class="flex gap-2">
                <div class="h-5 rounded bg-[#8b5cf6] flex-1"></div>
                <div class="h-5 rounded bg-[#ddd6fe] flex-1"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 04 -->
      <div class="timeline-step relative flex gap-5 pb-2" data-color="#22c55e">
        <div class="relative z-10 w-[48px] shrink-0 flex flex-col items-center">
          <div class="timeline-node w-11 h-11 rounded-xl bg-white border-2 border-[#e8e8e8] flex items-center justify-center transition-all duration-500">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" fill="#f0fdf4" stroke="#22c55e" stroke-width="1.5"/><path d="M8 12l3 3 5-6" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>
        <div class="cal-card p-5 flex-1 timeline-content opacity-50 translate-y-2 transition-all duration-500">
          <span class="text-[10px] font-bold tracking-wider text-[#9a9a9a] uppercase">Step 04</span>
          <h3 class="text-[17px] font-semibold text-[#242424] mt-1 mb-1.5" style="letter-spacing:-0.2px">Launch day</h3>
          <p class="text-[14px] leading-[1.6] text-[#6b6b6b]">Domain connected, SSL secured, analytics tracking live. Your customers start finding you on Google from day one.</p>
          <!-- Illustration: launch/rocket -->
          <div class="mt-4 p-4 rounded-xl bg-[#f0fdf4] border border-[#bbf7d0] text-center">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-[#22c55e] mb-2">
