---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Hero Illustration — Combined Concept">

<div class="px-4 py-8 max-w-[800px] mx-auto">
  <h1 class="font-cal text-[28px] font-bold text-[#242424] mb-2" style="letter-spacing:-0.035em">Combined: Before/After + Revenue Dashboard</h1>
  <p class="text-[14px] text-[#6b6b6b] mb-10">The transformation story with rich analytics. Premium hero illustration.</p>
</div>

<section class="grid-bg pb-16 px-4">
  <div class="max-w-[700px] mx-auto">
    <div class="cal-card p-4 sm:p-5">
      <div class="relative rounded bg-gradient-to-br from-[#eff6ff] via-[#f5f3ff]/50 to-[#f0fdf4]/30 border border-[#c7d2fe]/60 p-3 sm:p-4 overflow-hidden">
        <!-- Grid texture -->
        <div class="absolute inset-0 opacity-[0.03]" style="background-image:linear-gradient(to right,#000 1px,transparent 1px),linear-gradient(to bottom,#000 1px,transparent 1px);background-size:24px 24px"></div>

        <div class="relative z-10">
          <!-- Top: Before/After split -->
          <div class="flex gap-2 sm:gap-3 mb-3">
            <!-- BEFORE card (faded, grey, lifeless) -->
            <div class="flex-1 rounded bg-[#f0ede8] border border-[#d5d0c8] p-2.5 sm:p-3 relative">
              <div class="absolute top-1.5 left-2 text-[7px] font-bold text-[#9a9a9a] uppercase tracking-wider">Before</div>
              <div class="pt-4">
                <!-- Sad mini website -->
                <div class="rounded bg-[#e8e5df] border border-[#d5d0c8] overflow-hidden mb-2">
                  <div class="flex items-center gap-0.5 px-1.5 py-1 bg-[#ddd9d3]">
                    <span class="w-1 h-1 rounded-full bg-[#c5c0b8]"></span>
                    <span class="w-1 h-1 rounded-full bg-[#c5c0b8]"></span>
                    <span class="w-1 h-1 rounded-full bg-[#c5c0b8]"></span>
                  </div>
                  <div class="p-1.5">
                    <div class="h-1.5 rounded bg-[#c5c0b8] w-2/3 mb-1"></div>
                    <div class="h-1 rounded bg-[#d5d0c8] w-full mb-0.5"></div>
                    <div class="h-4 rounded bg-[#ddd9d3] mb-1"></div>
                    <div class="h-2.5 rounded bg-[#c5c0b8] w-1/2"></div>
                  </div>
                </div>
                <!-- Dead metrics -->
                <div class="flex gap-1">
                  <div class="flex-1 rounded bg-[#e8e5df] border border-[#d5d0c8] p-1 text-center">
                    <div class="text-[9px] font-bold text-[#9a9a9a]">0</div>
                    <div class="text-[5px] text-[#bbb]">Visitors</div>
                  </div>
                  <div class="flex-1 rounded bg-[#e8e5df] border border-[#d5d0c8] p-1 text-center">
                    <div class="text-[9px] font-bold text-[#9a9a9a]">$0</div>
                    <div class="text-[5px] text-[#bbb]">Revenue</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Transformation arrow -->
            <div class="flex items-center flex-shrink-0">
              <div class="w-7 h-7 sm:w-8 sm:h-8 rounded bg-gradient-to-br from-[#22c55e] to-[#16a34a] shadow-lg shadow-[#22c55e]/25 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </div>
            </div>

            <!-- AFTER card (vibrant, alive, premium) -->
            <div class="flex-1 rounded bg-white border border-[#86efac] shadow-lg shadow-[#22c55e]/8 p-2.5 sm:p-3 relative">
              <div class="absolute top-1.5 left-2 text-[7px] font-bold text-[#15803d] uppercase tracking-wider">After</div>
              <div class="pt-4">
                <!-- Vibrant mini website -->
                <div class="rounded bg-white border border-[#d0d0d0] shadow-sm overflow-hidden mb-2">
                  <div class="flex items-center gap-0.5 px-1.5 py-1 bg-[#f8f8f8] border-b border-[#e8e8e8]">
                    <span class="w-1 h-1 rounded-full bg-[#ff5f57]"></span>
                    <span class="w-1 h-1 rounded-full bg-[#ffbd2e]"></span>
                    <span class="w-1 h-1 rounded-full bg-[#28c840]"></span>
                  </div>
                  <div class="p-1.5">
                    <div class="h-1.5 rounded bg-[#242424] w-2/3 mb-1"></div>
                    <div class="h-1 rounded bg-[#9a9a9a] w-full mb-0.5"></div>
                    <div class="h-4 rounded bg-gradient-to-r from-[#dbeafe] via-[#ede9fe] to-[#fce7f3] mb-1"></div>
                    <div class="flex gap-0.5">
                      <div class="h-2.5 rounded bg-[#3b82f6] flex-1"></div>
                      <div class="h-2.5 rounded bg-[#f4f4f4] border border-[#e0e0e0] flex-1"></div>
                    </div>
                  </div>
                </div>
                <!-- Live metrics -->
                <div class="flex gap-1">
                  <div class="flex-1 rounded bg-[#f0fdf4] border border-[#86efac] p-1 text-center">
                    <div class="text-[9px] font-bold text-[#22c55e]">2,847</div>
                    <div class="text-[5px] text-[#15803d]">Visitors</div>
                  </div>
                  <div class="flex-1 rounded bg-[#eff6ff] border border-[#dbeafe] p-1 text-center">
                    <div class="text-[9px] font-bold text-[#3b82f6]">$12.8k</div>
                    <div class="text-[5px] text-[#1d4ed8]">Revenue</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Bottom: Revenue analytics dashboard -->
          <div class="rounded bg-white border border-[#d0d0d0] shadow-xl shadow-black/5 p-3 sm:p-4 illus-float">
            <!-- Dashboard header -->
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-2">
                <div class="w-7 h-7 sm:w-8 sm:h-8 rounded bg-gradient-to-br from-[#3b82f6] to-[#6366f1] shadow-md shadow-[#3b82f6]/20 flex items-center justify-center">
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>
                </div>
                <div>
                  <div class="text-[10px] sm:text-[11px] font-bold text-[#242424]">Revenue growth</div>
                  <div class="text-[7px] sm:text-[8px] text-[#9a9a9a]">Since launch</div>
                </div>
              </div>
              <div class="flex items-center gap-1.5 px-2 py-1 rounded bg-[#f0fdf4] border border-[#86efac] shadow-sm shadow-[#22c55e]/10">
                <div class="w-1.5 h-1.5 rounded-full bg-[#22c55e] animate-pulse"></div>
                <span class="text-[7px] sm:text-[8px] font-bold text-[#15803d]">Live</span>
              </div>
            </div>

            <!-- Revenue number -->
            <div class="mb-2">
              <div class="text-[24px] sm:text-[28px] font-bold text-[#242424] leading-none" style="letter-spacing:-0.03em">$12,840</div>
              <div class="flex items-center gap-1.5 mt-1">
                <div class="px-1.5 py-0.5 rounded bg-[#f0fdf4] border border-[#86efac]">
                  <span class="text-[7px] sm:text-[8px] font-bold text-[#15803d]">+$12,840</span>
                </div>
                <span class="text-[6px] sm:text-[7px] text-[#9a9a9a]">from $0 before launch</span>
              </div>
            </div>

            <!-- Chart with comparison line -->
            <div class="rounded bg-[#fafafa] border border-[#e8e8e8] p-2 mb-3">
              <div class="flex items-center justify-between mb-1">
                <span class="text-[6px] sm:text-[7px] text-[#9a9a9a]">Revenue</span>
                <div class="flex items-center gap-2">
                  <div class="flex items-center gap-0.5">
                    <div class="w-2 h-[2px] rounded bg-[#e0e0e0]"></div>
                    <span class="text-[5px] sm:text-[6px] text-[#bbb]">Before</span>
                  </div>
                  <div class="flex items-center gap-0.5">
                    <div class="w-2 h-[2px] rounded bg-[#22c55e]"></div>
                    <span class="text-[5px] sm:text-[6px] text-[#15803d]">After</span>
                  </div>
                </div>
              </div>
              <svg class="w-full h-10 sm:h-14" viewBox="0 0 300 50" fill="none" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="cg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#22c55e" stop-opacity="0.15"/><stop offset="100%" stop-color="#22c55e" stop-opacity="0"/></linearGradient>
                </defs>
                <!-- Before line (flat at bottom) -->
                <path d="M0 48 L300 48" stroke="#e0e0e0" stroke-width="1.5" stroke-dasharray="4 3"/>
                <!-- After line (shooting up) -->
                <path d="M0 46 Q30 44 60 42 Q90 38 120 30 Q150 24 180 16 Q210 10 240 6 Q270 4 300 2" stroke="#22c55e" stroke-width="2.5" fill="none"/>
                <path d="M0 46 Q30 44 60 42 Q90 38 120 30 Q150 24 180 16 Q210 10 240 6 Q270 4 300 2 V50 H0 Z" fill="url(#cg)"/>
                <circle cx="300" cy="2" r="3.5" fill="white" stroke="#22c55e" stroke-width="2"/>
              </svg>
            </div>

            <!-- Four metric cards -->
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px">
              <div class="rounded bg-gradient-to-b from-[#fefce8] to-white border border-[#fde047] p-1.5 text-center shadow-sm shadow-[#f59e0b]/5">
                <div class="w-5 h-5 rounded bg-gradient-to-br from-[#f59e0b] to-[#f97316] shadow-sm shadow-[#f59e0b]/20 flex items-center justify-center mx-auto mb-0.5">
                  <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/></svg>
                </div>
                <div class="text-[9px] sm:text-[10px] font-bold text-[#242424]">1.2s</div>
                <div class="text-[5px] sm:text-[6px] text-[#9a9a9a]">Speed</div>
              </div>
              <div class="rounded bg-gradient-to-b from-[#f0fdf4] to-white border border-[#86efac] p-1.5 text-center shadow-sm shadow-[#22c55e]/5">
                <div class="w-5 h-5 rounded bg-gradient-to-br from-[#22c55e] to-[#16a34a] shadow-sm shadow-[#22c55e]/20 flex items-center justify-center mx-auto mb-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
                </div>
                <div class="text-[9px] sm:text-[10px] font-bold text-[#242424]">98</div>
                <div class="text-[5px] sm:text-[6px] text-[#9a9a9a]">SEO</div>
              </div>
              <div class="rounded bg-gradient-to-b from-[#eff6ff] to-white border border-[#dbeafe] p-1.5 text-center shadow-sm shadow-[#3b82f6]/5">
                <div class="w-5 h-5 rounded bg-gradient-to-br from-[#3b82f6] to-[#6366f1] shadow-sm shadow-[#3b82f6]/20 flex items-center justify-center mx-auto mb-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
                </div>
                <div class="text-[9px] sm:text-[10px] font-bold text-[#242424]">2.8k</div>
                <div class="text-[5px] sm:text-[6px] text-[#9a9a9a]">Visitors</div>
              </div>
              <div class="rounded bg-gradient-to-b from-[#f5f3ff] to-white border border-[#a78bfa] p-1.5 text-center shadow-sm shadow-[#8b5cf6]/5">
                <div class="w-5 h-5 rounded bg-gradient-to-br from-[#8b5cf6] to-[#7c3aed] shadow-sm shadow-[#8b5cf6]/20 flex items-center justify-center mx-auto mb-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                </div>
                <div class="text-[9px] sm:text-[10px] font-bold text-[#242424]">47</div>
                <div class="text-[5px] sm:text-[6px] text-[#9a9a9a]">Enquiries</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating badges -->
        <div class="absolute -top-2 right-3 z-20">
          <div class="px-2 py-1.5 rounded bg-white border border-[#d0d0d0] shadow-lg shadow-black/5 flex items-center gap-1.5">
            <div class="w-5 h-5 rounded bg-gradient-to-br from-[#22c55e] to-[#16a34a] shadow-sm shadow-[#22c55e]/20 flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <div class="text-[7px] font-bold text-[#15803d]">New sale: $249</div>
              <div class="text-[5px] text-[#9a9a9a]">Just now</div>
            </div>
          </div>
        </div>
        <div class="absolute -bottom-2 left-3 z-20">
          <div class="px-2 py-1.5 rounded bg-white border border-[#d0d0d0] shadow-lg shadow-black/5 flex items-center gap-1.5">
            <div class="w-5 h-5 rounded bg-gradient-to-br from-[#3b82f6] to-[#6366f1] shadow-sm shadow-[#3b82f6]/20 flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>
            </div>
            <div>
              <div class="text-[7px] font-bold text-[#242424]">3 new enquiries</div>
              <div class="text-[5px] text-[#9a9a9a]">Today</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>
