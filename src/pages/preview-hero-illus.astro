---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Hero Illustration Options">

<div class="px-4 py-8 max-w-[800px] mx-auto">
  <h1 class="font-cal text-[28px] font-bold text-[#242424] mb-2" style="letter-spacing:-0.035em">Hero Illustration Options</h1>
  <p class="text-[14px] text-[#6b6b6b] mb-10">Four concepts. Each shown at mobile size inside the hero context.</p>
</div>

<!-- ═══════ OPTION 1: Revenue Dashboard ═══════ -->
<section class="grid-bg pb-12 px-4">
  <div class="max-w-[600px] mx-auto">
    <span class="inline-block px-3 py-1 rounded bg-[#3b82f6] text-white text-[12px] font-bold mb-4">Option 1: Revenue Dashboard</span>
    <div class="cal-card p-4">
      <div class="relative rounded bg-gradient-to-br from-[#eff6ff] via-[#f5f3ff]/60 to-[#f0fdf4]/40 border border-[#c7d2fe]/60 p-3 overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03]" style="background-image:linear-gradient(to right,#000 1px,transparent 1px),linear-gradient(to bottom,#000 1px,transparent 1px);background-size:30px 30px"></div>
        <div class="illus-float relative z-10">
          <div class="rounded bg-white border border-[#d0d0d0] shadow-xl shadow-[#3b82f6]/8 p-4">
            <!-- Header -->
            <div class="flex items-center justify-between mb-4">
              <div>
                <div class="text-[11px] font-bold text-[#242424]">Monthly revenue</div>
                <div class="text-[8px] text-[#9a9a9a]">From your website</div>
              </div>
              <div class="flex items-center gap-1 px-2 py-1 rounded bg-[#f0fdf4] border border-[#86efac]">
                <div class="w-1.5 h-1.5 rounded-full bg-[#22c55e] animate-pulse"></div>
                <span class="text-[7px] font-bold text-[#15803d]">Live</span>
              </div>
            </div>
            <!-- Big number -->
            <div class="mb-3">
              <div class="text-[32px] font-bold text-[#242424] leading-none" style="letter-spacing:-0.03em">$12,840</div>
              <div class="flex items-center gap-1 mt-1">
                <div class="px-1.5 py-0.5 rounded bg-[#f0fdf4] border border-[#86efac]">
                  <span class="text-[8px] font-bold text-[#15803d]">+34%</span>
                </div>
                <span class="text-[7px] text-[#9a9a9a]">vs last month</span>
              </div>
            </div>
            <!-- Clean line chart -->
            <div class="rounded bg-[#fafafa] border border-[#e8e8e8] p-2 mb-3">
              <svg class="w-full h-12" viewBox="0 0 280 48" fill="none" preserveAspectRatio="none">
                <defs><linearGradient id="rv" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#22c55e" stop-opacity="0.12"/><stop offset="100%" stop-color="#22c55e" stop-opacity="0"/></linearGradient></defs>
                <path d="M0 40 Q40 38 80 32 Q120 28 160 20 Q200 16 240 8 Q260 5 280 3" stroke="#22c55e" stroke-width="2" fill="none"/>
                <path d="M0 40 Q40 38 80 32 Q120 28 160 20 Q200 16 240 8 Q260 5 280 3 V48 H0 Z" fill="url(#rv)"/>
                <circle cx="280" cy="3" r="3" fill="white" stroke="#22c55e" stroke-width="2"/>
              </svg>
            </div>
            <!-- Two metric pills -->
            <div class="flex gap-2">
              <div class="flex-1 rounded bg-[#fefce8] border border-[#fde047] p-2 text-center">
                <div class="text-[12px] font-bold text-[#242424]">847</div>
                <div class="text-[7px] text-[#9a9a9a]">Visitors</div>
              </div>
              <div class="flex-1 rounded bg-[#eff6ff] border border-[#dbeafe] p-2 text-center">
                <div class="text-[12px] font-bold text-[#242424]">4.2%</div>
                <div class="text-[7px] text-[#9a9a9a]">Conversion</div>
              </div>
            </div>
          </div>
        </div>
        <!-- Floating notification -->
        <div class="absolute -top-2 right-2 z-20">
          <div class="px-2 py-1.5 rounded bg-white border border-[#d0d0d0] shadow-lg flex items-center gap-1.5">
            <div class="w-5 h-5 rounded bg-gradient-to-br from-[#22c55e] to-[#16a34a] shadow-sm shadow-[#22c55e]/20 flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v3.586L7.707 11.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 00-1.414-1.414L11 10.586V7z"/></svg>
            </div>
            <span class="text-[7px] font-bold text-[#15803d]">New sale</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ OPTION 2: Before/After ═══════ -->
<section class="grid-bg pb-12 px-4">
  <div class="max-w-[600px] mx-auto">
    <span class="inline-block px-3 py-1 rounded bg-[#f97316] text-white text-[12px] font-bold mb-4">Option 2: Before / After</span>
    <div class="cal-card p-4">
      <div class="relative rounded bg-gradient-to-br from-[#eff6ff] via-[#f5f3ff]/60 to-[#f0fdf4]/40 border border-[#c7d2fe]/60 p-3 overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03]" style="background-image:linear-gradient(to right,#000 1px,transparent 1px),linear-gradient(to bottom,#000 1px,transparent 1px);background-size:30px 30px"></div>
        <div class="illus-float relative z-10 flex gap-2">
          <!-- Before -->
          <div class="flex-1 rounded bg-[#f4f4f4] border border-[#e0e0e0] p-3 opacity-60">
            <div class="text-[8px] font-bold text-[#9a9a9a] uppercase tracking-wider mb-2">Before</div>
            <div class="h-1.5 rounded bg-[#d0d0d0] w-3/4 mb-1"></div>
            <div class="h-1 rounded bg-[#e0e0e0] w-full mb-1"></div>
            <div class="h-6 rounded bg-[#e8e8e8] mb-1.5"></div>
            <div class="flex gap-1">
              <div class="h-3 rounded bg-[#d0d0d0] flex-1"></div>
              <div class="h-3 rounded bg-[#e0e0e0] flex-1"></div>
            </div>
            <div class="mt-2 text-center">
              <div class="text-[10px] font-bold text-[#9a9a9a]">0</div>
              <div class="text-[6px] text-[#bbb]">Visitors</div>
            </div>
          </div>
          <!-- Arrow -->
          <div class="flex items-center px-1">
            <svg class="w-4 h-4 text-[#22c55e]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </div>
          <!-- After -->
          <div class="flex-1 rounded bg-white border border-[#86efac] shadow-lg shadow-[#22c55e]/10 p-3">
            <div class="text-[8px] font-bold text-[#15803d] uppercase tracking-wider mb-2">After</div>
            <div class="h-1.5 rounded bg-[#242424] w-3/4 mb-1"></div>
            <div class="h-1 rounded bg-[#9a9a9a] w-full mb-1"></div>
            <div class="h-6 rounded bg-gradient-to-r from-[#dbeafe] via-[#ede9fe] to-[#fce7f3] mb-1.5"></div>
            <div class="flex gap-1">
              <div class="h-3 rounded bg-[#3b82f6] flex-1"></div>
              <div class="h-3 rounded bg-[#f4f4f4] border border-[#e0e0e0] flex-1"></div>
            </div>
            <div class="mt-2 text-center">
              <div class="text-[10px] font-bold text-[#22c55e]">2,847</div>
              <div class="text-[6px] text-[#15803d]">Visitors</div>
            </div>
          </div>
        </div>
        <!-- Floating metric -->
        <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 z-20">
          <div class="px-3 py-1.5 rounded bg-white border border-[#d0d0d0] shadow-lg flex items-center gap-2">
            <svg class="w-3.5 h-3.5 text-[#22c55e]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22"/></svg>
            <span class="text-[8px] font-bold text-[#242424]">+2,847 visitors in 30 days</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ OPTION 3: Website + Results ═══════ -->
<section class="grid-bg pb-12 px-4">
  <div class="max-w-[600px] mx-auto">
    <span class="inline-block px-3 py-1 rounded bg-[#8b5cf6] text-white text-[12px] font-bold mb-4">Option 3: Website + Floating Results</span>
    <div class="cal-card p-4">
      <div class="relative rounded bg-gradient-to-br from-[#eff6ff] via-[#f5f3ff]/60 to-[#f0fdf4]/40 border border-[#c7d2fe]/60 p-3 overflow-hidden" style="min-height:240px">
        <div class="absolute inset-0 opacity-[0.03]" style="background-image:linear-gradient(to right,#000 1px,transparent 1px),linear-gradient(to bottom,#000 1px,transparent 1px);background-size:30px 30px"></div>
        <!-- Central website mockup -->
        <div class="illus-float relative z-10 mx-auto w-[180px]">
          <div class="rounded bg-white border border-[#d0d0d0] shadow-xl shadow-black/8 overflow-hidden">
            <div class="flex items-center gap-1 px-2 py-1 bg-[#f8f8f8] border-b border-[#e8e8e8]">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff5f57]"></span>
              <span class="w-1.5 h-1.5 rounded-full bg-[#ffbd2e]"></span>
              <span class="w-1.5 h-1.5 rounded-full bg-[#28c840]"></span>
              <div class="flex-1 mx-1 h-2.5 rounded bg-white border border-[#e0e0e0]"></div>
            </div>
            <div class="p-2">
              <div class="h-2 rounded bg-[#242424] w-2/3 mb-1"></div>
              <div class="h-1 rounded bg-[#d0d0d0] w-full mb-1"></div>
              <div class="h-8 rounded bg-gradient-to-r from-[#dbeafe] via-[#ede9fe] to-[#fce7f3] mb-1.5"></div>
              <div class="flex gap-1">
                <div class="h-3.5 rounded bg-[#3b82f6] flex-1"></div>
                <div class="h-3.5 rounded bg-[#f4f4f4] border border-[#e0e0e0] flex-1"></div>
              </div>
            </div>
          </div>
        </div>
        <!-- Floating metric badges around the website -->
        <div class="absolute top-2 left-2 z-20">
          <div class="px-2 py-1.5 rounded bg-white border border-[#d0d0d0] shadow-lg illus-float">
            <div class="text-[10px] font-bold text-[#242424]">2,847</div>
            <div class="text-[6px] text-[#9a9a9a]">Visitors</div>
          </div>
        </div>
        <div class="absolute top-2 right-2 z-20">
          <div class="px-2 py-1.5 rounded bg-white border border-[#86efac] shadow-lg illus-float" style="animation-delay:0.3s">
            <div class="text-[10px] font-bold text-[#22c55e]">98</div>
            <div class="text-[6px] text-[#15803d]">SEO score</div>
          </div>
        </div>
        <div class="absolute bottom-3 left-3 z-20">
          <div class="px-2 py-1.5 rounded bg-white border border-[#fde047] shadow-lg illus-float" style="animation-delay:0.6s">
            <div class="text-[10px] font-bold text-[#f59e0b]">1.2s</div>
            <div class="text-[6px] text-[#b45309]">Load time</div>
          </div>
        </div>
        <div class="absolute bottom-3 right-3 z-20">
          <div class="px-2 py-1.5 rounded bg-white border border-[#ddd6fe] shadow-lg illus-float" style="animation-delay:0.9s">
            <div class="text-[10px] font-bold text-[#8b5cf6]">24</div>
            <div class="text-[6px] text-[#7c3aed]">Enquiries</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ OPTION 4: Growth Timeline ═══════ -->
<section class="grid-bg pb-12 px-4">
  <div class="max-w-[600px] mx-auto">
    <span class="inline-block px-3 py-1 rounded bg-[#22c55e] text-white text-[12px] font-bold mb-4">Option 4: Growth Timeline</span>
    <div class="cal-card p-4">
      <div class="relative rounded bg-gradient-to-br from-[#eff6ff] via-[#f5f3ff]/60 to-[#f0fdf4]/40 border border-[#c7d2fe]/60 p-4 overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03]" style="background-image:linear-gradient(to right,#000 1px,transparent 1px),linear-gradient(to bottom,#000 1px,transparent 1px);background-size:30px 30px"></div>
        <div class="illus-float relative z-10">
          <!-- Timeline track -->
          <div class="flex items-start gap-0">
            <!-- Month 1 -->
            <div class="flex-1 text-center">
              <div class="w-8 h-8 rounded bg-[#eff6ff] border border-[#dbeafe] flex items-center justify-center mx-auto mb-1.5 shadow-sm">
                <svg class="w-4 h-4 text-[#3b82f6]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58"/></svg>
              </div>
              <div class="text-[8px] font-bold text-[#3b82f6] mb-0.5">Launch</div>
              <div class="rounded bg-white border border-[#dbeafe] p-1.5 shadow-sm">
                <div class="text-[11px] font-bold text-[#242424]">120</div>
                <div class="text-[6px] text-[#9a9a9a]">Visitors</div>
              </div>
            </div>
            <!-- Arrow -->
            <div class="pt-4 px-1">
              <svg class="w-3 h-3 text-[#d0d0d0]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </div>
            <!-- Month 2 -->
            <div class="flex-1 text-center">
              <div class="w-8 h-8 rounded bg-[#f5f3ff] border border-[#ddd6fe] flex items-center justify-center mx-auto mb-1.5 shadow-sm">
                <svg class="w-4 h-4 text-[#8b5cf6]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22"/></svg>
              </div>
              <div class="text-[8px] font-bold text-[#8b5cf6] mb-0.5">Month 2</div>
              <div class="rounded bg-white border border-[#ddd6fe] p-1.5 shadow-sm">
                <div class="text-[11px] font-bold text-[#242424]">890</div>
                <div class="text-[6px] text-[#9a9a9a]">Visitors</div>
              </div>
            </div>
            <!-- Arrow -->
            <div class="pt-4 px-1">
              <svg class="w-3 h-3 text-[#d0d0d0]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </div>
            <!-- Month 3 -->
            <div class="flex-1 text-center">
              <div class="w-8 h-8 rounded bg-[#f0fdf4] border border-[#86efac] flex items-center justify-center mx-auto mb-1.5 shadow-sm">
                <svg class="w-4 h-4 text-[#22c55e]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div class="text-[8px] font-bold text-[#22c55e] mb-0.5">Month 3</div>
              <div class="rounded bg-white border border-[#86efac] shadow-lg shadow-[#22c55e]/10 p-1.5">
                <div class="text-[11px] font-bold text-[#22c55e]">2,847</div>
                <div class="text-[6px] text-[#15803d]">Visitors</div>
              </div>
            </div>
          </div>
          <!-- Bottom summary -->
          <div class="mt-3 rounded bg-white border border-[#d0d0d0] p-2 flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-1.5">
              <div class="w-5 h-5 rounded bg-gradient-to-br from-[#22c55e] to-[#16a34a] flex items-center justify-center">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15M12 4.5h7.5V12"/></svg>
              </div>
              <span class="text-[8px] font-bold text-[#242424]">+2,273% growth</span>
            </div>
            <span class="text-[7px] text-[#9a9a9a]">90 days</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>
