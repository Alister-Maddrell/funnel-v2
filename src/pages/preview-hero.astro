---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Hero Animation Options">

<div class="px-4 py-8 max-w-[1100px] mx-auto">
  <h1 class="font-cal text-[28px] font-bold text-[#242424] mb-2" style="letter-spacing:-0.035em">Hero Animation Options</h1>
  <p class="text-[14px] text-[#6b6b6b] mb-10">Three animation styles. Mobile: above the title. Desktop: to the right.</p>
</div>

<!-- ═══════════════ OPTION 1: Website Being Built (IMPROVED) ═══════════════ -->
<section class="grid-bg pb-16">
  <div class="px-4 py-4 max-w-[1100px] mx-auto">
    <span class="inline-block px-3 py-1 rounded-full bg-[#3b82f6] text-white text-[12px] font-bold mb-4">Option 1: Website Being Built</span>
  </div>
  <div class="cal-card mx-3 sm:mx-4 md:mx-auto md:max-w-[1100px]">
    <div class="px-5 pt-8 pb-6 sm:px-8 sm:pt-12 md:px-10 md:pt-14">
      <div class="flex flex-col md:flex-row md:items-center md:gap-12">
        <div class="mb-6 md:mb-0 md:order-2 md:w-[420px] flex-shrink-0">
          <div class="relative rounded-2xl bg-gradient-to-br from-[#fafafa] to-[#f0f0f0] border border-[#e8e8e8] p-3 sm:p-4 overflow-hidden shadow-sm" style="min-height:320px">
            <!-- Browser chrome with Live indicator -->
            <div class="flex items-center gap-1.5 mb-3 anim-fade" style="animation-delay:0.2s">
              <div class="flex gap-1.5">
                <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
                <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
                <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
              </div>
              <div class="flex-1 mx-2 h-5 rounded-lg bg-white border border-[#e0e0e0] flex items-center px-2">
                <svg class="w-3 h-3 text-[#22c55e] mr-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                <span class="text-[8px] text-[#9a9a9a]">yourbusiness.com.au</span>
              </div>
              <div class="flex items-center gap-1 anim-pop" style="animation-delay:2.5s">
                <div class="w-1.5 h-1.5 rounded-full bg-[#22c55e] animate-pulse"></div>
                <span class="text-[7px] font-bold text-[#22c55e]">Live</span>
              </div>
            </div>
            <!-- Nav -->
            <div class="flex items-center justify-between mb-4 px-1 anim-slide-right" style="animation-delay:0.5s">
              <div class="w-14 h-3.5 rounded bg-[#242424]"></div>
              <div class="flex items-center gap-2">
                <div class="w-10 h-2 rounded bg-[#d0d0d0]"></div>
                <div class="w-10 h-2 rounded bg-[#d0d0d0]"></div>
                <div class="px-2.5 py-1.5 rounded-lg bg-[#3b82f6] shadow-sm shadow-[#3b82f6]/20">
                  <div class="w-8 h-1.5 rounded bg-white/60"></div>
                </div>
              </div>
            </div>
            <!-- Hero content -->
            <div class="mb-3 px-1 anim-scale-in" style="animation-delay:0.8s">
              <div class="h-4 rounded-md bg-[#242424] w-[80%] mb-2"></div>
              <div class="h-4 rounded-md bg-[#242424] w-[55%] mb-3"></div>
              <div class="h-2 rounded bg-[#d0d0d0] w-[70%] mb-1"></div>
              <div class="h-2 rounded bg-[#d0d0d0] w-[50%] mb-4"></div>
              <div class="flex gap-2">
                <div class="h-7 rounded-lg bg-[#22c55e] shadow-sm shadow-[#22c55e]/20 flex-1 max-w-[80px] anim-pop" style="animation-delay:1.3s"></div>
                <div class="h-7 rounded-lg bg-white border border-[#e0e0e0] flex-1 max-w-[80px] anim-pop" style="animation-delay:1.5s"></div>
              </div>
            </div>
            <!-- Hero image with layered shapes -->
            <div class="rounded-xl overflow-hidden mb-3 anim-slide-up" style="animation-delay:1.1s">
              <div class="h-24 bg-gradient-to-br from-[#dbeafe] via-[#e0e7ff] to-[#ede9fe] relative">
                <div class="absolute top-3 left-4 w-16 h-10 rounded-lg bg-white/30 border border-white/50"></div>
                <div class="absolute top-5 left-8 w-20 h-12 rounded-lg bg-white/20 border border-white/40"></div>
                <div class="absolute bottom-2 right-3 w-10 h-6 rounded-md bg-[#8b5cf6]/20 border border-[#8b5cf6]/30"></div>
              </div>
            </div>
            <!-- Loading progress bar -->
            <div class="mb-3 px-1 anim-fade" style="animation-delay:1.5s">
              <div class="h-1 rounded-full bg-[#e8e8e8] overflow-hidden">
                <div class="h-full rounded-full bg-gradient-to-r from-[#3b82f6] via-[#8b5cf6] to-[#22c55e] w-[85%] progress-bar"></div>
              </div>
            </div>
            <!-- Feature cards -->
            <div class="grid grid-cols-3 gap-2 anim-fade" style="animation-delay:1.7s">
              <div class="rounded-xl bg-white border border-[#e8e8e8] p-2.5 shadow-sm">
                <div class="w-7 h-7 rounded-lg bg-[#eff6ff] border border-[#dbeafe] flex items-center justify-center mb-1.5">
                  <div class="w-3.5 h-3.5 rounded bg-[#3b82f6]"></div>
                </div>
                <div class="h-1.5 rounded bg-[#d0d0d0] w-full mb-1"></div>
                <div class="h-1.5 rounded bg-[#e8e8e8] w-2/3"></div>
              </div>
              <div class="rounded-xl bg-white border border-[#e8e8e8] p-2.5 shadow-sm">
                <div class="w-7 h-7 rounded-lg bg-[#fff7ed] border border-[#fed7aa] flex items-center justify-center mb-1.5">
                  <div class="w-3.5 h-3.5 rounded bg-[#f97316]"></div>
                </div>
                <div class="h-1.5 rounded bg-[#d0d0d0] w-full mb-1"></div>
                <div class="h-1.5 rounded bg-[#e8e8e8] w-3/4"></div>
              </div>
              <div class="rounded-xl bg-white border border-[#e8e8e8] p-2.5 shadow-sm">
                <div class="w-7 h-7 rounded-lg bg-[#f5f3ff] border border-[#ddd6fe] flex items-center justify-center mb-1.5">
                  <div class="w-3.5 h-3.5 rounded bg-[#8b5cf6]"></div>
                </div>
                <div class="h-1.5 rounded bg-[#d0d0d0] w-full mb-1"></div>
                <div class="h-1.5 rounded bg-[#e8e8e8] w-1/2"></div>
              </div>
            </div>
            <!-- Sparkles -->
            <div class="absolute top-10 right-3 w-3 h-3 rounded-full bg-[#3b82f6] anim-sparkle" style="animation-delay:2s"></div>
            <div class="absolute bottom-20 right-6 w-2.5 h-2.5 rounded-full bg-[#f97316] anim-sparkle" style="animation-delay:2.3s"></div>
            <div class="absolute top-24 left-2 w-2.5 h-2.5 rounded-full bg-[#22c55e] anim-sparkle" style="animation-delay:2.6s"></div>
          </div>
        </div>
        <div class="flex-1 md:order-1">
          <a href="#" class="cal-pill mb-6">
            <svg class="w-4 h-4 text-[#6349ea]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Sydney's premium web studio
          </a>
          <h1 class="font-cal text-[36px] sm:text-[40px] md:text-[52px] font-bold leading-[1.08] text-[#242424] mb-5" style="letter-spacing:-0.035em;text-wrap:balance">The better way to launch your business online</h1>
          <p class="text-[14px] sm:text-[15px] leading-[1.65] text-[#6b6b6b] max-w-[380px] mb-7">Bespoke websites for ambitious local businesses. Designed for conversions, delivered in 10 days.</p>
          <div class="max-w-[320px] flex flex-col gap-2.5">
            <a href="#" class="cal-btn-full chevron">Get your website</a>
            <a href="#" class="cal-btn-full-outline chevron">Free consultation</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ OPTION 2: Dashboard Analytics (NEW) ═══════════════ -->
<section class="grid-bg pb-16">
  <div class="px-4 py-4 max-w-[1100px] mx-auto">
    <span class="inline-block px-3 py-1 rounded-full bg-[#f97316] text-white text-[12px] font-bold mb-4">Option 2: Dashboard Analytics</span>
  </div>
  <div class="cal-card mx-3 sm:mx-4 md:mx-auto md:max-w-[1100px]">
    <div class="px-5 pt-8 pb-6 sm:px-8 sm:pt-12 md:px-10 md:pt-14">
      <div class="flex flex-col md:flex-row md:items-center md:gap-12">
        <div class="mb-6 md:mb-0 md:order-2 md:w-[420px] flex-shrink-0">
          <div class="relative py-4" style="min-height:320px">
            <!-- Main dashboard card -->
            <div class="dashboard-float relative z-10 mx-auto w-[300px] sm:w-[340px] rounded-2xl bg-white border border-[#e0e0e0] shadow-xl p-4">
              <!-- Header -->
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-[#3b82f6] to-[#8b5cf6] flex items-center justify-center">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18"/><path stroke-linecap="round" stroke-linejoin="round" d="M18 17V9M13 17V5M8 17v-3"/></svg>
                  </div>
                  <div>
                    <div class="text-[11px] font-semibold text-[#242424]">Your Website</div>
                    <div class="text-[9px] text-[#9a9a9a]">Last 30 days</div>
                  </div>
                </div>
                <div class="flex items-center gap-1 px-2 py-1 rounded-lg bg-[#f0fdf4] border border-[#bbf7d0]">
                  <div class="w-1.5 h-1.5 rounded-full bg-[#22c55e] animate-pulse"></div>
                  <span class="text-[8px] font-bold text-[#22c55e]">Live</span>
                </div>
              </div>
              <!-- Visitor count -->
              <div class="mb-3">
                <div class="text-[9px] text-[#9a9a9a] mb-0.5">Total visitors</div>
                <div class="text-[28px] font-bold text-[#242424] leading-none" style="letter-spacing:-0.02em">2,847</div>
                <div class="flex items-center gap-1 mt-1">
                  <svg class="w-3 h-3 text-[#22c55e]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5h7.5V12"/></svg>
                  <span class="text-[9px] font-semibold text-[#22c55e]">+24% this month</span>
                </div>
              </div>
              <!-- Mini chart -->
              <div class="mb-3">
                <svg class="w-full h-12" viewBox="0 0 300 48" fill="none">
                  <defs>
                    <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="#22c55e" stop-opacity="0.15"/>
                      <stop offset="100%" stop-color="#22c55e" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                  <path d="M0 40 Q30 38 60 35 Q90 30 120 28 Q150 32 180 22 Q210 18 240 12 Q270 8 300 4" stroke="#22c55e" stroke-width="2" fill="none" class="chart-line"/>
                  <path d="M0 40 Q30 38 60 35 Q90 30 120 28 Q150 32 180 22 Q210 18 240 12 Q270 8 300 4 V48 H0 Z" fill="url(#chartGrad)"/>
                </svg>
              </div>
              <!-- Metric cards -->
              <div class="grid grid-cols-3 gap-2">
                <div class="rounded-xl bg-[#fefce8] border border-[#fef08a] p-2 text-center">
                  <svg class="w-4 h-4 text-[#f59e0b] mx-auto mb-1" fill="currentColor" viewBox="0 0 20 20"><path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/></svg>
                  <div class="text-[10px] font-bold text-[#242424]">1.2s</div>
                  <div class="text-[7px] text-[#9a9a9a]">Speed</div>
                </div>
                <div class="rounded-xl bg-[#f0fdf4] border border-[#bbf7d0] p-2 text-center">
                  <svg class="w-4 h-4 text-[#22c55e] mx-auto mb-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
                  <div class="text-[10px] font-bold text-[#242424]">98</div>
                  <div class="text-[7px] text-[#9a9a9a]">SEO</div>
                </div>
                <div class="rounded-xl bg-[#f5f3ff] border border-[#ddd6fe] p-2 text-center">
                  <svg class="w-4 h-4 text-[#8b5cf6] mx-auto mb-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
                  <div class="text-[10px] font-bold text-[#242424]">142</div>
                  <div class="text-[7px] text-[#9a9a9a]">Leads</div>
                </div>
              </div>
            </div>
            <!-- Notification badge floating -->
            <div class="absolute top-2 right-4 sm:right-8 z-20">
              <div class="px-3 py-2 rounded-xl bg-white border border-[#e8e8e8] shadow-lg flex items-center gap-2">
                <div class="w-6 h-6 rounded-full bg-[#3b82f6] flex items-center justify-center">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>
                </div>
                <div>
                  <div class="text-[9px] font-semibold text-[#242424]">3 new enquiries</div>
                  <div class="text-[7px] text-[#9a9a9a]">Just now</div>
                </div>
              </div>
            </div>
            <!-- Sparkles -->
            <div class="absolute top-12 left-2 w-2.5 h-2.5 rounded-full bg-[#3b82f6] anim-sparkle" style="animation-delay:1.5s"></div>
            <div class="absolute bottom-8 right-6 w-2 h-2 rounded-full bg-[#22c55e] anim-sparkle" style="animation-delay:2.2s"></div>
            <div class="absolute bottom-16 left-6 w-2 h-2 rounded-full bg-[#f97316] anim-sparkle" style="animation-delay:2.8s"></div>
          </div>
        </div>
        <div class="flex-1 md:order-1">
          <a href="#" class="cal-pill mb-6">
            <svg class="w-4 h-4 text-[#6349ea]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Sydney's premium web studio
          </a>
          <h1 class="font-cal text-[36px] sm:text-[40px] md:text-[52px] font-bold leading-[1.08] text-[#242424] mb-5" style="letter-spacing:-0.035em;text-wrap:balance">The better way to launch your business online</h1>
          <p class="text-[14px] sm:text-[15px] leading-[1.65] text-[#6b6b6b] max-w-[380px] mb-7">Bespoke websites for ambitious local businesses. Designed for conversions, delivered in 10 days.</p>
          <div class="max-w-[320px] flex flex-col gap-2.5">
            <a href="#" class="cal-btn-full chevron">Get your website</a>
            <a href="#" class="cal-btn-full-outline chevron">Free consultation</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ OPTION 3: Abstract Design Flow (IMPROVED) ═══════════════ -->
<section class="grid-bg pb-16">
  <div class="px-4 py-4 max-w-[1100px] mx-auto">
    <span class="inline-block px-3 py-1 rounded-full bg-[#8b5cf6] text-white text-[12px] font-bold mb-4">Option 3: Abstract Design Flow</span>
  </div>
  <div class="cal-card mx-3 sm:mx-4 md:mx-auto md:max-w-[1100px]">
    <div class="px-5 pt-8 pb-6 sm:px-8 sm:pt-12 md:px-10 md:pt-14">
      <div class="flex flex-col md:flex-row md:items-center md:gap-12">
        <div class="mb-6 md:mb-0 md:order-2 md:w-[420px] flex-shrink-0">
          <div class="relative rounded-2xl bg-[#fafafa] border border-[#e8e8e8] overflow-hidden p-4" style="min-height:340px">
            <!-- Grid lines (slightly thicker) -->
            <svg class="absolute inset-0 w-full h-full" viewBox="0 0 420 340" fill="none">
              <line x1="0" y1="85" x2="420" y2="85" stroke="#ddd" stroke-width="1.5" class="grid-draw" style="animation-delay:0.2s"/>
              <line x1="0" y1="170" x2="420" y2="170" stroke="#ddd" stroke-width="1.5" class="grid-draw" style="animation-delay:0.4s"/>
              <line x1="0" y1="255" x2="420" y2="255" stroke="#ddd" stroke-width="1.5" class="grid-draw" style="animation-delay:0.6s"/>
              <line x1="105" y1="0" x2="105" y2="340" stroke="#ddd" stroke-width="1.5" class="grid-draw-v" style="animation-delay:0.3s"/>
              <line x1="210" y1="0" x2="210" y2="340" stroke="#ddd" stroke-width="1.5" class="grid-draw-v" style="animation-delay:0.5s"/>
              <line x1="315" y1="0" x2="315" y2="340" stroke="#ddd" stroke-width="1.5" class="grid-draw-v" style="animation-delay:0.7s"/>
            </svg>
            <!-- CTA Button element -->
            <div class="absolute top-5 left-5 anim-float-in" style="animation-delay:0.8s">
              <div class="px-5 py-2.5 rounded-xl bg-[#3b82f6] shadow-lg shadow-[#3b82f6]/25 flex items-center gap-2">
                <div class="w-4 h-4 rounded-md bg-white/30"></div>
                <div class="w-14 h-2.5 rounded bg-white/60"></div>
              </div>
            </div>
            <!-- Content card with mini illustration -->
            <div class="absolute top-16 right-4 anim-float-in" style="animation-delay:1.1s">
              <div class="w-40 rounded-xl bg-white border border-[#e8e8e8] shadow-lg p-3">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-8 h-8 rounded-xl bg-[#f0fdf4] border border-[#bbf7d0] flex items-center justify-center">
                    <svg class="w-4 h-4 text-[#22c55e]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </div>
                  <div class="flex-1">
                    <div class="h-2 rounded bg-[#242424] w-3/4 mb-1"></div>
                    <div class="h-1.5 rounded bg-[#d0d0d0] w-full"></div>
                  </div>
                </div>
                <div class="h-1.5 rounded bg-[#e0e0e0] w-full mb-1"></div>
                <div class="h-1.5 rounded bg-[#e8e8e8] w-2/3"></div>
              </div>
            </div>
            <!-- Sparkle card with avatar -->
            <div class="absolute bottom-16 left-5 anim-float-in" style="animation-delay:1.4s">
              <div class="w-32 h-32 rounded-2xl bg-gradient-to-br from-[#eff6ff] via-[#f5f3ff] to-[#fdf2f8] border border-[#e0e7ff] shadow-lg p-3 flex flex-col items-center justify-center">
                <div class="w-10 h-10 rounded-xl bg-[#8b5cf6] mb-2 flex items-center justify-center shadow-md shadow-[#8b5cf6]/20">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
                </div>
                <div class="h-1.5 rounded bg-[#c4b5fd] w-full mb-1"></div>
                <div class="h-1.5 rounded bg-[#ddd6fe] w-3/4"></div>
              </div>
            </div>
            <!-- Orange pill (larger, with text) -->
            <div class="absolute top-[150px] left-[110px] anim-float-in" style="animation-delay:1.3s">
              <div class="px-4 py-2 rounded-full bg-[#f97316] shadow-lg shadow-[#f97316]/25 flex items-center gap-1.5">
                <div class="w-3 h-3 rounded-full bg-white/30"></div>
                <div class="w-16 h-2 rounded bg-white/60"></div>
              </div>
            </div>
